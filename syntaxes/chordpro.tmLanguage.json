{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "ChordPro",
    "fileTypes": ["cho", "chordpro", "chopro"],
    "scopeName": "source.chordpro",
    "patterns": [
        {"include": "#comment"},
        {"include": "#delegate-block"},
        {"include": "#directive"},
        {"include": "#chord"}
    ],
    "repository": {
        "comment": {
            "name": "comment.line.number-sign.chordpro",
            "match": "^(#)(.*)$",
            "captures": {
                "1": {"name": "punctuation.definition.comment.chordpro"},
                "2": {"name": "comment.line.chordpro"}
            }
        },
        "delegate-block": {
            "begin": "(?i)({)(start_of_(?:abc|ly|lilypond|svg|textblock))(})",
            "beginCaptures": {
                "1": {"name": "punctuation.definition.directive.begin.chordpro"},
                "2": {"name": "keyword.control.directive.chordpro"},
                "3": {"name": "punctuation.definition.directive.end.chordpro"}
            },
            "end": "(?i)({)(end_of_(?:abc|ly|lilypond|svg|textblock))(})",
            "endCaptures": {
                "1": {"name": "punctuation.definition.directive.begin.chordpro"},
                "2": {"name": "keyword.control.directive.chordpro"},
                "3": {"name": "punctuation.definition.directive.end.chordpro"}
            },
            "contentName": "markup.raw.block.chordpro"
        },
        "directive": {
            "match": "({)([a-zA-Z_][a-zA-Z0-9_]*)(?:\\s*(:)\\s*((?:[^{}]*?)))?\\s*(})",
            "captures": {
                "1": {"name": "punctuation.definition.directive.begin.chordpro"},
                "2": {"name": "keyword.control.directive.chordpro"},
                "3": {"name": "punctuation.separator.directive.chordpro"},
                "4": {"name": "string.unquoted.directive-value.chordpro"},
                "5": {"name": "punctuation.definition.directive.end.chordpro"}
            }
        },
        "chord": {
            "match": "(\\[)([^\\[\\]]*)(\\])",
            "captures": {
                "1": {"name": "punctuation.definition.chord.begin.chordpro"},
                "2": {"name": "entity.name.chord.chordpro"},
                "3": {"name": "punctuation.definition.chord.end.chordpro"}
            }
        }
    }
}
