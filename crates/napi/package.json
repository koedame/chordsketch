{
  "name": "@chordsketch/node",
  "version": "0.3.0",
  "description": "Native Node.js addon for ChordPro parsing and rendering via napi-rs.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/koedame/chordsketch.git",
    "directory": "crates/napi"
  },
  "homepage": "https://github.com/koedame/chordsketch",
  "engines": {
    "node": ">=15.12.0"
  },
  "keywords": [
    "chordpro",
    "music",
    "chord",
    "parser",
    "lyrics",
    "napi-rs",
    "node-addon",
    "n-api",
    "native"
  ],
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "optionalDependencies": {
    "@chordsketch/node-linux-x64-gnu": "0.2.2",
    "@chordsketch/node-linux-arm64-gnu": "0.2.2",
    "@chordsketch/node-darwin-x64": "0.2.2",
    "@chordsketch/node-darwin-arm64": "0.2.2",
    "@chordsketch/node-win32-x64-msvc": "0.2.2"
  },
  "napi": {
    "binaryName": "chordsketch-napi",
    "packageName": "@chordsketch/node",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.4.0",
    "jest": "^29.7.0"
  },
  "scripts": {
    "build": "napi build --release --manifest-path Cargo.toml",
    "build:debug": "napi build --manifest-path Cargo.toml",
    "test": "jest"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ]
  }
}
