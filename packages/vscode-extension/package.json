{
  "name": "chordsketch",
  "displayName": "ChordSketch",
  "description": "ChordPro language support with syntax highlighting, diagnostics, completions, and a live HTML preview panel.",
  "version": "0.2.0",
  "publisher": "koedame",
  "icon": "icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Other"
  ],
  "keywords": [
    "chordpro",
    "chord",
    "music",
    "lyrics",
    "cho"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/koedame/chordsketch.git",
    "directory": "packages/vscode-extension"
  },
  "homepage": "https://github.com/koedame/chordsketch",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "chordpro",
        "aliases": [
          "ChordPro",
          "chordpro"
        ],
        "extensions": [
          ".cho",
          ".chordpro",
          ".chopro"
        ],
        "configuration": "./dist/syntaxes/language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "chordpro",
        "scopeName": "source.chordpro",
        "path": "./dist/syntaxes/chordpro.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "chordsketch.openPreview",
        "title": "ChordSketch: Open Preview",
        "icon": "$(open-preview)"
      },
      {
        "command": "chordsketch.openPreviewToSide",
        "title": "ChordSketch: Open Preview to the Side",
        "icon": "$(open-preview)"
      },
      {
        "command": "chordsketch.transposeUp",
        "title": "ChordSketch: Transpose Up"
      },
      {
        "command": "chordsketch.transposeDown",
        "title": "ChordSketch: Transpose Down"
      },
      {
        "command": "chordsketch.convertTo",
        "title": "ChordSketch: Export As…"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "chordsketch.openPreviewToSide",
          "when": "editorLangId == chordpro",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "chordsketch.openPreview",
          "when": "editorLangId == chordpro"
        },
        {
          "command": "chordsketch.openPreviewToSide",
          "when": "editorLangId == chordpro"
        },
        {
          "command": "chordsketch.transposeUp",
          "when": "editorLangId == chordpro"
        },
        {
          "command": "chordsketch.transposeDown",
          "when": "editorLangId == chordpro"
        },
        {
          "command": "chordsketch.convertTo",
          "when": "editorLangId == chordpro"
        }
      ]
    },
    "configuration": {
      "title": "ChordSketch",
      "properties": {
        "chordsketch.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the ChordSketch Language Server for diagnostics, completions, hover, and formatting."
        },
        "chordsketch.lsp.path": {
          "type": "string",
          "default": "",
          "description": "Path to the chordsketch-lsp binary. If empty, the extension looks on the system PATH first, then falls back to the bundled binary (if present)."
        },
        "chordsketch.preview.defaultMode": {
          "type": "string",
          "enum": [
            "html",
            "text"
          ],
          "enumDescriptions": [
            "Open the preview in HTML rendering mode.",
            "Open the preview in plain text mode."
          ],
          "default": "html",
          "description": "Default view mode when opening a new ChordSketch preview panel. Takes effect only when no persisted state exists for that panel (first open or after state is cleared). Changes to this setting require opening a new preview to take effect."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "build:watch": "node esbuild.mjs --watch",
    "lint": "tsc --noEmit",
    "test": "node --experimental-transform-types --test 'src/**/*.test.ts'",
    "package": "vsce package --no-dependencies",
    "prepackage": "npm run build"
  },
  "dependencies": {
    "@chordsketch/wasm": "^0.2.0",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.2",
    "esbuild": "^0.24.2",
    "ovsx": "^0.10.10",
    "typescript": "^5.7.3"
  }
}
