{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    // Required so `*.test.ts` files can import sibling `.ts` modules
    // by full filename — matches the convention used in
    // `src/*.test.ts`, which is executed directly by
    // `node --experimental-transform-types`.
    "allowImportingTsExtensions": true
  },
  "include": ["./**/*.ts", "./**/*.tsx"]
}
