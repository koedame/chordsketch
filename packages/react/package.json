{
  "name": "@chordsketch/react",
  "version": "0.0.0",
  "description": "React components for ChordPro rendering, powered by @chordsketch/wasm",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/koedame/chordsketch.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/koedame/chordsketch",
  "bugs": {
    "url": "https://github.com/koedame/chordsketch/issues"
  },
  "keywords": [
    "chordpro",
    "music",
    "chord",
    "parser",
    "lyrics",
    "react",
    "react-component",
    "wasm",
    "webassembly"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && node -e \"require('fs').copyFileSync('src/styles.css','dist/styles.css')\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@chordsketch/wasm": "^0.2.2"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "sideEffects": [
    "./dist/styles.css"
  ],
  "publishConfig": {
    "access": "public"
  }
}
