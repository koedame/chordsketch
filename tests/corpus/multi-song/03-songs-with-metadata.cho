{key: Am}
{tempo: 72}
{time: 3/4}
{capo: 3}

{start_of_verse}
[Am]Orange sky is [Dm]fading fast
[E]Another day has [Am]passed
{end_of_verse}

{start_of_chorus}
[Dm]Rest, [Am]rest with the [E]moon
[F]Night is [E]coming [Am]soon
{end_of_chorus}

{new_song}

{title: Midnight}
{subtitle: Nocturne}
{artist: The Night Owls}
{key: Em}
{tempo: 60}
{time: 6/8}
{capo: 5}

{start_of_verse}
[Em]Darkness wraps the [Am]world in [B]sleep
[Em]Silence running [Am]wide and [B]deep
{end_of_verse}

{start_of_chorus}
