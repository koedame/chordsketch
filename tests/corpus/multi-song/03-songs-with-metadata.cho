{title: Sunrise}
{subtitle: Morning Movement}
{artist: The Dawn Chorus}
{key: G}
{tempo: 100}
{time: 4/4}
{capo: 0}

{start_of_verse}
[G]Golden light is [C]breaking through
[D]Morning dew on [G]everything
{end_of_verse}

{start_of_chorus}
[C]Rise, [G]rise with the [D]sun
[Em]A new day has [C]be[D]gun
{end_of_chorus}

{new_song}

{title: Sunset}
{subtitle: Evening Movement}
