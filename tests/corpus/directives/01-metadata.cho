{title: The Long Road Home}
{subtitle: A Journey Song}
{artist: The Wanderers}
{composer: John Smith}
{lyricist: Jane Doe}
{copyright: 2024 Wanderer Records}
{album: Distant Horizons}
{year: 2024}
{key: G}
